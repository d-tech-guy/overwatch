generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model School {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  shortName      String?         @map("short_name")
  aliases        String[]
  state          String?
  country        String?
  logoUrl        String?         @map("logo_url")
  approved       Boolean         @default(false)
  suspendedAt    DateTime?       @map("suspended_at") @db.Timestamptz(6)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)
  admins         Admin[]
  investigations Investigation[]

  @@map("schools")
}

model Admin {
  id        String      @id @db.Uuid
  fullName  String      @map("full_name")
  email     String
  schoolId  String?     @map("school_id") @db.Uuid
  role      String
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)
  notes     AdminNote[]
  school    School?     @relation(fields: [schoolId], references: [id])

  @@map("admins")
}

model Investigation {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  publicId            String               @unique @default(dbgenerated("gen_random_uuid()")) @map("public_id") @db.Uuid
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)
  completedAt         DateTime?            @map("completed_at") @db.Timestamptz(6)
  submittedUrl        String               @map("submitted_url")
  submittedBy         String?              @map("submitted_by") @db.Uuid
  submissionIpHash    String?              @map("submission_ip_hash")
  processingStatus    ProcessingStatus     @default(queued) @map("processing_status")
  investigationStatus InvestigationStatus  @default(pending_review) @map("investigation_status")
  progress            Int                  @default(0)
  authorUsername      String?              @map("author_username")
  caption             String?
  uploadTimestamp     DateTime?            @map("upload_timestamp") @db.Timestamptz(6)
  hashtags            String[]
  commentCount        Int?                 @map("comment_count")
  likeCount           Int?                 @map("like_count")
  shareCount          Int?                 @map("share_count")
  detectedSchoolId    String?              @map("detected_school_id") @db.Uuid
  detectedLocation    String?              @map("detected_location")
  sentiment           String?
  severity            Severity?
  riskScore           Int?                 @map("risk_score")
  confidenceScore     Int?                 @map("confidence_score")
  summary             String?
  explanation         String?
  aiResponseJson      Json?                @map("ai_response_json")
  adminNotes          AdminNote[]
  evidence            Evidence[]
  events              InvestigationEvent[]
  school              School?              @relation(fields: [detectedSchoolId], references: [id])

  @@index([processingStatus], map: "idx_investigations_processing_status")
  @@index([investigationStatus], map: "idx_investigations_investigation_status")
  @@index([detectedSchoolId], map: "idx_investigations_detected_school_id")
  @@index([createdAt], map: "idx_investigations_created_at")
  @@index([publicId], map: "idx_investigations_public_id")
  @@map("investigations")
}

model InvestigationEvent {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  investigationId String        @map("investigation_id") @db.Uuid
  event           String
  description     String?
  progress        Int?
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  investigation   Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  @@index([investigationId], map: "idx_investigation_events_investigation_id")
  @@map("investigation_events")
}

model Evidence {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  investigationId String        @map("investigation_id") @db.Uuid
  type            EvidenceType
  content         String
  source          String?
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  investigation   Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  @@index([investigationId], map: "idx_evidence_investigation_id")
  @@map("evidence")
}

model AdminNote {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  investigationId String        @map("investigation_id") @db.Uuid
  adminId         String        @map("admin_id") @db.Uuid
  note            String
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  admin           Admin         @relation(fields: [adminId], references: [id], onDelete: Cascade)
  investigation   Investigation @relation(fields: [investigationId], references: [id], onDelete: Cascade)

  @@index([investigationId], map: "idx_admin_notes_investigation_id")
  @@map("admin_notes")
}

enum ProcessingStatus {
  queued
  validating_url
  creating_investigation
  fetching_video_metadata
  video_metadata_complete
  fetching_profile
  profile_complete
  fetching_comments
  comments_complete
  preparing_ai_context
  calling_gemini
  ai_analysis_complete
  generating_report
  saving_results
  completed
  failed

  @@map("processing_status")
}

enum InvestigationStatus {
  pending_review
  under_review
  resolved
  archived

  @@map("investigation_status")
}

enum Severity {
  low
  medium
  high
  critical

  @@map("severity")
}

enum EvidenceType {
  caption
  hashtag
  comment
  metadata
  ai_evidence

  @@map("evidence_type")
}

model Application {
  id                    String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  publicId              String            @default(dbgenerated("gen_random_uuid()")) @map("public_id") @db.Uuid
  // Institution details
  institutionName       String            @map("institution_name")
  institutionType       String            @default("Unknown") @map("institution_type") // Public | Private | Government
  officialEmail         String            @default("unknown@example.com") @map("official_email")
  website               String?
  address               String?
  city                  String?
  state                 String?
  country               String            @default("")
  schoolPhone           String?           @map("school_phone")
  // Administrator details
  administratorName     String            @map("administrator_name")
  administratorPosition String            @default("Administrator") @map("administrator_position")
  administratorEmail    String            @map("administrator_email")
  administratorPhone    String            @default("0000000000") @map("administrator_phone")
  // Application details
  reason                String
  status                String            @default("pending")
  notes                 String?
  // Approval metadata
  approvedBy            String?           @map("approved_by") @db.Uuid
  approvedAt            DateTime?         @map("approved_at") @db.Timestamptz(6)
  schoolId              String?           @map("school_id") @db.Uuid
  adminUserId           String?           @map("admin_user_id") @db.Uuid
  // Rejection metadata
  rejectedBy            String?           @map("rejected_by") @db.Uuid
  rejectedAt            DateTime?         @map("rejected_at") @db.Timestamptz(6)
  rejectionReason       String?           @map("rejection_reason")
  // Suspension metadata
  suspendedBy           String?           @map("suspended_by") @db.Uuid
  suspendedAt           DateTime?         @map("suspended_at") @db.Timestamptz(6)
  suspensionReason      String?           @map("suspension_reason")
  // Timestamps
  submittedAt           DateTime          @default(now()) @map("submitted_at") @db.Timestamptz(6)
  updatedAt             DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([status], map: "idx_applications_status")
  @@index([administratorEmail], map: "idx_applications_administrator_email")
  @@map("applications")
}

model AuditLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType     String   @map("entity_type") // "application" | "investigation" | "school" | etc.
  entityId       String   @map("entity_id") @db.Uuid
  action         String   // "approved" | "rejected" | "suspended" | etc.
  previousStatus String?  @map("previous_status")
  newStatus      String?  @map("new_status")
  performedBy    String?  @map("performed_by") @db.Uuid
  reason         String?
  correlationId  String?  @map("correlation_id") @db.Uuid
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([entityType, entityId], map: "idx_audit_log_entity")
  @@index([performedBy], map: "idx_audit_log_performed_by")
  @@map("audit_logs")
}

model Raid {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  institutionId  String?   @map("institution_id") @db.Uuid
  status         RaidStatus @default(queued)
  keywords       String[]
  hashtags       String[]
  creators       String[]
  configuration  Json?
  startedAt      DateTime? @map("started_at") @db.Timestamptz(6)
  completedAt    DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  jobs           RaidJob[]

  @@map("raids")
}

model RaidJob {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  raidId      String       @map("raid_id") @db.Uuid
  provider    String
  status      RaidStatus   @default(queued)
  progress    Int          @default(0)
  targetUrl   String?      @map("target_url")
  startedAt   DateTime?    @map("started_at") @db.Timestamptz(6)
  completedAt DateTime?    @map("completed_at") @db.Timestamptz(6)
  raid        Raid         @relation(fields: [raidId], references: [id], onDelete: Cascade)

  @@index([raidId], map: "idx_raid_jobs_raid_id")
  @@map("raid_jobs")
}

model Creator {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creatorId        String    @unique @map("creator_id")
  username         String
  displayName      String?   @map("display_name")
  profileUrl       String?   @map("profile_url")
  followerCount    Int?      @map("follower_count")
  verificationStatus Boolean @default(false) @map("verification_status")
  riskScore        Int?      @map("risk_score")
  firstSeen        DateTime  @default(now()) @map("first_seen") @db.Timestamptz(6)
  lastSeen         DateTime  @default(now()) @map("last_seen") @db.Timestamptz(6)

  @@map("creators")
}

model Keyword {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  keyword        String    @unique
  category       String?
  frequency      Int       @default(1)
  riskAssociation Int?     @map("risk_association")
  firstSeen      DateTime  @default(now()) @map("first_seen") @db.Timestamptz(6)
  lastSeen       DateTime  @default(now()) @map("last_seen") @db.Timestamptz(6)

  @@map("keywords")
}

model Hashtag {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hashtag        String    @unique
  frequency      Int       @default(1)
  growthRate     Float?    @map("growth_rate")
  threatLevel    Int?      @map("threat_level")
  firstSeen      DateTime  @default(now()) @map("first_seen") @db.Timestamptz(6)
  lastSeen       DateTime  @default(now()) @map("last_seen") @db.Timestamptz(6)

  @@map("hashtags")
}

enum RaidStatus {
  queued
  searching
  collecting
  processing
  completed
  cancelled
  failed
  timed_out

  @@map("raid_status")
}
